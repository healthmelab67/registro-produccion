<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulario de Ingreso de Datos Health-me lab</title>
    <style>
        /* Paleta de colores basada en Health-me lab */
        :root {
            --azul-oscuro: #0f2c59;      /* Azul corporativo principal */
            --verde-medico: #00a896;     /* Verde turquesa de acento */
            --azul-claro: #eef2f7;       /* Fondo suave */
            --texto-oscuro: #333333;
            --blanco: #ffffff;
        }

        body { 
            font-family: 'Segoe UI', Arial, sans-serif; 
            background-color: var(--azul-claro); 
            padding: 20px;
            margin: 0;
            color: var(--texto-oscuro);
        }

        /* Contenedor del Logo */
        .logo-header {
            text-align: center;
            margin-bottom: 20px;
        }
        .logo-header img {
            max-width: 180px;
            height: auto;
        }
        
        /* Contenedor del Login */
        .login-container { 
            max-width: 400px; 
            background: var(--blanco); 
            padding: 35px 30px; 
            border-radius: 12px; 
            box-shadow: 0 8px 24px rgba(15, 44, 89, 0.15); 
            margin: 80px auto 0 auto; 
        }
        
        /* Contenedor del Formulario (Oculto al inicio) */
        .form-container { 
            max-width: 550px; 
            background: var(--blanco); 
            padding: 35px 30px; 
            border-radius: 12px; 
            box-shadow: 0 8px 24px rgba(15, 44, 89, 0.15); 
            margin: 20px auto; 
            display: none; 
        }
        
        h2 { 
            text-align: center; 
            color: var(--azul-oscuro); 
            margin-top: 10px;
            margin-bottom: 25px; 
            font-weight: 700;
        }

        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: bold; color: var(--azul-oscuro); }
        .form-group input, .form-group select, .form-group textarea { 
            width: 100%; 
            padding: 12px; 
            border: 2px solid #dce2e9; 
            border-radius: 6px; 
            box-sizing: border-box; 
            font-size: 14px;
            transition: border-color 0.3s;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            outline: none;
            border-color: var(--verde-medico);
        }
        .form-group textarea { resize: vertical; height: 90px; }
        
        /* Botones Estilizados con los colores corporativos */
        .btn-login { 
            width: 100%; 
            background-color: var(--azul-oscuro); 
            color: white; 
            padding: 14px; 
            border: none; 
            border-radius: 6px; 
            cursor: pointer; 
            font-size: 16px; 
            font-weight: bold; 
            margin-top: 15px;
            transition: background 0.3s;
        }
        .btn-login:hover { background-color: #0b1f40; }

        .btn-submit { 
            width: 100%; 
            background-color: var(--verde-medico); 
            color: white; 
            padding: 14px; 
            border: none; 
            border-radius: 6px; 
            cursor: pointer; 
            font-size: 16px; 
            font-weight: bold; 
            transition: background 0.3s;
        }
        .btn-submit:hover { background-color: #008f80; }
        
        #mensaje, #login-error { display: none; text-align: center; padding: 12px; margin-top: 20px; font-weight: bold; border-radius: 6px; }
        .exito { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .error { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    </style>
</head>
<body>

<div class="login-container" id="loginVista">
    <div class="logo-header">
        <img src="Logo_HT_HT4.png" alt="Logo_HT_HT4.png">
    </div>
    <h2>Control de Acceso</h2>
    <div class="form-group">
        <label for="login-user">Usuario:</label>
        <input type="text" id="login-user" placeholder="Ingresa tu usuario">
    </div>
    <div class="form-group">
        <label for="login-pass">Contraseña:</label>
        <input type="password" id="login-pass" placeholder="Ingresa tu contraseña">
    </div>
    <button class="btn-login" id="btnIngresar">Iniciar Sesión</button>
    <div id="login-error" class="error">Usuario o contraseña incorrectos.</div>
</div>


<div class="form-container" id="formularioVista">
    <div class="logo-header">
        <img src="Logo_HT_HT4.png" alt="Health-me lab Logo">
    </div>
    <h2>Registro de Producción</h2>
    
    <form id="miFormulario" action="https://script.google.com/macros/s/AKfycbwBp9f1r5LE3D-Qo9OoAIGRPno2Kp7jIJDgczVBFAYpQUI4ucfdXtXE2trO70kqV1Lw/exec" method="POST">
        
        <div class="form-group">
            <label for="fecha">Fecha:</label>
            <input type="date" id="fecha" name="fecha" required>
        </div>

        <div class="form-group">
            <label for="producto">Producto:</label>
            <input type="text" id="producto" name="producto" required>
        </div>

        <div class="form-group">
            <label for="cantidad">Cantidad Producida:</label>
            <input type="number" id="cantidad" name="cantidad" min="0" step="any" required>
        </div>

        <div class="form-group">
            <label for="producto_terminado">¿Producto Terminado?</label>
            <select id="producto_terminado" name="producto_terminado" required>
                <option value="" disabled selected>Seleccione una opción</option>
                <option value="si">Sí</option>
                <option value="no">No</option>
            </select>
        </div>

        <div class="form-group">
            <label for="cubetas">Número de Cubetas:</label>
            <input type="number" id="cubetas" name="cubetas" min="0" required>
        </div>

        <div class="form-group">
            <label for="temp_inicial">Temperatura Inicial (Base) °C:</label>
            <input type="number" id="temp_inicial" name="temp_inicial" step="0.1" required>
        </div>

        <div class="form-group">
            <label for="temp_intermedia">Temperatura Intermedia (Base) °C:</label>
            <input type="number" id="temp_intermedia" name="temp_intermedia" step="0.1" required>
        </div>

        <div class="form-group">
            <label for="temp_final">Temperatura Final (Base) °C:</label>
            <input type="number" id="temp_final" name="temp_final" step="0.1" required>
        </div>

        <div class="form-group">
            <label for="comentarios">Comentarios:</label>
            <textarea id="comentarios" name="comentarios"></textarea>
        </div>

        <button type="submit" class="btn-submit" id="btnEnviar">Guardar Registro</button>
    </form>
    
    <div id="mensaje"></div>
</div>

<script>
    // === LÓGICA DEL LOGIN ===
    const USUARIO_VALIDO = "admin";
    const PASSWORD_VALIDO = "healthme2026"; // Cambia esta contraseña si lo deseas

    const loginVista = document.getElementById('loginVista');
    const formularioVista = document.getElementById('formularioVista');
    const btnIngresar = document.getElementById('btnIngresar');
    const loginError = document.getElementById('login-error');

    btnIngresar.addEventListener('click', () => {
        const user = document.getElementById('login-user').value;
        const pass = document.getElementById('login-pass').value;

        if (user === USUARIO_VALIDO && pass === PASSWORD_VALIDO) {
            loginVista.style.display = 'none'; 
            formularioVista.style.display = 'block'; 
            inicializarFecha(); 
        } else {
            loginError.style.display = 'block'; 
        }
    });

    // === LÓGICA DEL FORMULARIO ORIGINAL ===
    function inicializarFecha() {
        const hoy = new Date();
        const yyyy = hoy.getFullYear();
        let mm = String(hoy.getMonth() + 1).padStart(2, '0');
        let dd = String(hoy.getDate()).padStart(2, '0');
        document.getElementById('fecha').value = `${yyyy}-${mm}-${dd}`;
    }

    const formulario = document.getElementById('miFormulario');
    const mensajeDiv = document.getElementById('mensaje');
    const btnEnviar = document.getElementById('btnEnviar');

    formulario.addEventListener('submit', function(e) {
        e.preventDefault(); 
        
        btnEnviar.disabled = true;
        btnEnviar.innerText = "Enviando...";
        mensajeDiv.style.display = "none";

        const datos = new FormData(formulario);

        fetch(formulario.action, {
            method: 'POST',
            body: datos
        })
        .then(response => response.json())
        .then(data => {
            if(data.result === 'success') {
                mensajeDiv.innerText = "¡Datos guardados con éxito en Google Sheets!";
                mensajeDiv.className = "exito";
                mensajeDiv.style.display = "block";
                
                formulario.reset();
                inicializarFecha(); 
            } else {
                throw new Error();
            }
        })
        .catch(error => {
            mensajeDiv.innerText = "Hubo un error al guardar los datos.";
            mensajeDiv.className = "error";
            mensajeDiv.style.display = "block";
        })
        .finally(() => {
            btnEnviar.disabled = false;
            btnEnviar.innerText = "Guardar Registro";
        });
    });
</script>

</body>
</html>
